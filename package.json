{
  "name": "anyelo-dev",
  "private": true,
  "type": "module",
  "scripts": {
    "build:tokens": "node ./tools/generate-tokens.mjs",
    "build:css": "tailwindcss -c ./config/tailwind.config.cjs -i ./styles/app.css -o ./public/assets/app.css --minify",
    "build:js": "esbuild ./scripts/app.js --bundle --format=esm --minify --outfile=./public/assets/app.js",
    "build": "npm run build:tokens && npm run build:css && npm run build:js",
    "dev:css": "tailwindcss -c ./config/tailwind.config.cjs -i ./styles/app.css -o ./public/assets/app.css --watch",
    "dev:js": "esbuild ./scripts/app.js --bundle --format=esm --sourcemap --outfile=./public/assets/app.js --watch",
    "dev": "npm-run-all -p dev:css dev:js",
    "lint": "node ./tools/validate-content.mjs"
  },
  "dependencies": {
    "gsap": "^3.13.0",
    "lenis": "^1.3.8",
    "lucide": "^0.541.0"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.5",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "yaml": "^2.8.0"
  }
}
